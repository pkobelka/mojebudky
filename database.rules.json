{
  "rules": {
    ".read": false,
    ".write": false,

    "aquactrl_udalosti": {
      ".read": "auth != null",
      "$id": {
        ".write": "auth != null && ( auth.token.admin === true || (newData.exists() && (data.exists() || newData.child('zadal').val() === auth.token.person)) )"
      }
    },
    "aquactrl_ukoly": {
      ".read": "auth != null",
      ".indexOn": ["resitel", "stav"],
      "$id": {
        ".write": "auth != null && ( auth.token.admin === true || (!data.exists() && newData.child('zadal').val() === auth.token.person) || (data.exists() && (data.child('zadal').val() === auth.token.person || data.child('resitel').val() === auth.token.person)) )"
      }
    },
    "aquactrl_absence": {
      ".read": "auth != null",
      "$kdo": {
        ".write": "auth != null && (auth.token.person === $kdo || auth.token.admin === true)"
      }
    },
    "aquactrl_zarizeni":    { ".read": "auth != null", ".write": "auth != null" },
    "aquactrl_presence":    { ".read": "auth != null", ".write": "auth != null" },
    "aquactrl_push_tokens": { ".read": "auth != null", ".write": "auth != null" },
    "aquactrl_outbox":      { ".read": "auth != null", ".write": "auth != null" },
    "aquactrl_login_email": { ".read": "auth != null", ".write": "auth.token.admin === true" },

    "florian_kandidati":   { ".read": "auth != null", ".write": "auth != null" },
    "florian_domereni":    { ".read": "auth != null", ".write": "auth != null" },
    "florian_foto":        { ".read": "auth != null", ".write": "auth != null" },
    "florian_ukoly":       { ".read": "auth != null", ".write": "auth != null" },
    "florian_lide":        { ".read": "auth != null", ".write": "auth != null" },
    "florian_push_tokens": { ".read": "auth != null", ".write": "auth != null" },
    "florian_zarizeni":    { ".read": "auth != null", ".write": "auth != null" },
    "florian_outbox":      { ".read": "auth != null", ".write": "auth != null" },
    "florian_gis_requests":{ ".read": "auth != null", ".write": "auth != null" },
    "florian_login_email": { ".read": "auth != null", ".write": "auth.token.admin === true" },
    "florian_revize":      { ".read": "auth != null", ".write": "auth.token.admin === true" },
    "florian_config":      { ".read": "auth != null", ".write": "auth.token.admin === true" },

    "presence":          { ".read": true, ".write": true },
    "aktivita":          { ".read": true, ".write": true },
    "budky_edit":        { ".read": true, ".write": true },
    "admin_requests":    { ".read": true, ".write": true },
    "spravci":           { ".read": true, ".write": true },
    "spravce_aktivita":  { ".read": true, ".write": true },
    "prihlaseni":        { ".read": true, ".write": true },
    "navstevnost_log":   { ".read": true, ".write": true, ".indexOn": ["ts"] },
    "navstevnost_celkem": { ".read": true, ".write": true },
    "navstevnost_denne": { ".read": true, ".write": true },
    "push_broadcast": { ".read": true, ".write": true },
    "push_history":   { ".read": true, ".write": true },
    "push_tokens": {
      "$id": { ".read": true, ".write": true }
    },
    "zpravy_spravci": {
      "$loginId": { ".read": true, ".write": true }
    },
    "hesla": {
      "$uid": { ".read": true, ".write": true }
    }
  }
}
